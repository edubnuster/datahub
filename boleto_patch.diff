+def _barcode_itf_blocks(code44: str) -> List[Dict[str, float]]:
+    digits = _normalize_digits(code44)
+    if len(digits) != 44:
+        return []
+    patterns = {
+        "0": "nnwwn",
+        "1": "wnnnw",
+        "2": "nwnnw",
+        "3": "wwnnn",
+        "4": "nnwnw",
+        "5": "wnwnn",
+        "6": "nwwnn",
+        "7": "nnnww",
+        "8": "wnnwn",
+        "9": "nwnwn",
+    }
+    sequence: List[tuple] = [("bar", 1), ("space", 1), ("bar", 1), ("space", 1)]
+    for i in range(0, len(digits), 2):
+        left = patterns[digits[i]]
+        right = patterns[digits[i + 1]]
+        for idx in range(5):
+            sequence.append(("bar", 3 if left[idx] == "w" else 1))
+            sequence.append(("space", 3 if right[idx] == "w" else 1))
+    sequence.extend([("bar", 3), ("space", 1), ("bar", 1)])
+    xpos = 0.0
+    blocks: List[Dict[str, float]] = []
+    for kind, width in sequence:
+        if kind == "bar":
+            blocks.append({"x": xpos, "w": float(width)})
+        xpos += float(width)
+    if xpos <= 0:
+        return []
+    for item in blocks:
+        item["x"] = item["x"] / xpos
+        item["w"] = item["w"] / xpos
+    return blocks
