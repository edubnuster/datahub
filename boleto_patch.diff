+    convenio = str(boleto_data.get("portador_convenio") or "").strip()
+    contract = str(boleto_data.get("portador_contrato") or "").strip()
+
+    bank_code = code[:3] or barcode_digits[:3] or line_digits[:3] or "000"
+    bank_name = "PORTADOR NÃO IDENTIFICADO"
+    if bank_code == "001" or "BRASIL" in name:
+        bank_code = "001"
+        bank_name = "BANCO DO BRASIL"
+    elif bank_code == "033" or "SANTANDER" in name:
+        bank_code = "033"
+        bank_name = "SANTANDER"
+    elif bank_code == "104" or "CAIXA" in name:
+        bank_code = "104"
+        bank_name = "CAIXA ECONÔMICA FEDERAL"
+    elif bank_code == "237" or "BRADESCO" in name:
+        bank_code = "237"
+        bank_name = "BRADESCO"
+    elif bank_code == "341" or "ITAU" in name or "ITAÚ" in name:
+        bank_code = "341"
+        bank_name = "ITAÚ UNIBANCO"
+    elif bank_code == "748" or "SICREDI" in name:
+        bank_code = "748"
+        bank_name = "SICREDI"
+    elif bank_code == "756" or "SICOOB" in name:
+        bank_code = "756"
+        bank_name = "SICOOB"
+    elif bank_code == "422" or "SAFRA" in name:
+        bank_code = "422"
+        bank_name = "BANCO SAFRA"
+    elif bank_code in ("041", "004") or "BANRISUL" in name:
+        bank_code = "041"
+        bank_name = "BANRISUL"
+    elif name:
+        bank_name = name
+
+    wallet_label = carteira or "N/I"
