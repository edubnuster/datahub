 def _pdf_escape(text: str) -> str:
     return text.replace("\\", "\\\\").replace("(", "\\(").replace(")", "\\)")
 
+def _normalize_digits(value: Any) -> str:
+    return re.sub(r"\D", "", str(value or ""))
+
+
+def _wrap_text(text: str, max_chars: int = 92) -> List[str]:
+    clean = str(text or "").strip()
+    if not clean:
+        return [""]
+    words = clean.split()
+    lines: List[str] = []
+    current = ""
+    for word in words:
+        candidate = f"{current} {word}".strip()
+        if len(candidate) <= max_chars:
+            current = candidate
+            continue
+        if current:
+            lines.append(current)
+        current = word
+    if current:
+        lines.append(current)
+    return lines or [clean]
+
+
+def _resolve_portador_layout(boleto_data: Dict[str, Any]) -> Dict[str, str]:
+    code = _normalize_digits(boleto_data.get("portador_codigo"))
